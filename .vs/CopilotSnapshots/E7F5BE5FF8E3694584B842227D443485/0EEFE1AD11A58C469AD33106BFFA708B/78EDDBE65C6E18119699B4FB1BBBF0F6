                    await ShowMenuAsync(fileEngine, protectionEngine);
                    break;
                case "2":
                    ApplyLabels(fileEngine);
                    await ShowMenuAsync(fileEngine, protectionEngine);
                    break;
                case "3":
                    await ApplyProtectionAndPermissionsAsync(fileEngine);
                    await ShowMenuAsync(fileEngine, protectionEngine);
