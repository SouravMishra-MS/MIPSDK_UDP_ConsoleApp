<configuration>
  <appSettings>
    <add key="ClientId" value="{YOUR-AAD-APP-CLIENT-ID}"/>
    <add key="TenantGuid" value="organizations"/>
    <add key="Authority" value="https://login.microsoftonline.com/"/>
    <add key="app:Name" value="{ENTER-THE-APP-NAME}"/>
    <add key="app:Version" value="{ENTER-THE-APP-VERSION}"/>
  </appSettings>
</configuration>
